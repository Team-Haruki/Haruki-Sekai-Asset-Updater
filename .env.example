# Haruki Sekai Asset Updater local/compose environment

# Docker / compose
HTTP_PORT=8080
RUST_LOG=info

# Local runtime config path override
# HARUKI_CONFIG_PATH=./haruki-asset-configs.yaml

# Cloud-native config loading. When HARUKI_CONFIG_URI is set, it takes
# precedence over HARUKI_CONFIG_PATH and local default config discovery.
# HARUKI_CONFIG_URI=opendal://config/haruki-asset-configs.yaml
# HARUKI_CONFIG_OPENDAL_SCHEME=fs
# HARUKI_CONFIG_OPENDAL_ROOT=./config-store
# HARUKI_CONFIG_OPENDAL_OPTION_BUCKET=sekai-configs
# HARUKI_CONFIG_OPENDAL_OPTION_ENDPOINT=https://s3.example.com
# HARUKI_CONFIG_OPENDAL_OPTION_REGION=auto
# HARUKI_CONFIG_OPENDAL_OPTION_ACCESS_KEY_ID=
# HARUKI_CONFIG_OPENDAL_OPTION_SECRET_ACCESS_KEY=

# AssetStudio CLI path
# Local run: absolute path on your machine
# Docker compose: leave empty and let the container default point at /app/assetstudio/AssetStudioCLI
HARUKI_ASSET_STUDIO_CLI_PATH=

# Required when using the tracked local config (haruki-asset-configs.yaml)
# Shared key/iv are used by JP/TW/KR/CN in the local config.
HARUKI_SHARED_AES_KEY_HEX=
HARUKI_SHARED_AES_IV_HEX=

# EN-specific key/iv used by the local config.
HARUKI_EN_AES_KEY_HEX=
HARUKI_EN_AES_IV_HEX=

# Optional if you later switch config values to env references for auth/storage/git.
# HARUKI_BEARER_TOKEN=
# HARUKI_STORAGE_ACCESS_KEY_ID=
# HARUKI_STORAGE_SECRET_ACCESS_KEY=
# HARUKI_GIT_SYNC_PASSWORD=

# Cloud-native env overrides use double underscores as path separators.
# These are applied after haruki-asset-configs.yaml and ${env:...} expansion.
# HARUKI__SERVER__PORT=8080
# HARUKI__LOGGING__LEVEL=info
# HARUKI__EXECUTION__WORKSPACE__WORK_DIR=/var/run/haruki/work
# HARUKI__EXECUTION__WORKSPACE__EXPORT_DIR=/var/run/haruki/exports/{region}/{job_id}
# HARUKI__REGIONS__JP__ENABLED=true
# HARUKI__REGIONS__JP__UPLOAD__ENABLED=false
# HARUKI__REGIONS__JP__EXPORT__ASSET_STUDIO__EXPORT_TYPES__0=textAsset
# HARUKI__STORAGE__PROVIDERS__0__SCHEME=s3
# HARUKI__STORAGE__PROVIDERS__0__OPTIONS__BUCKET=sekai-jp-assets
